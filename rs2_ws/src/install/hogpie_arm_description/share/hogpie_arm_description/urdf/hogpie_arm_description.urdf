<?xml version="1.0"?>

<robot name="hogpie_arm">

  <!-- ====================================================== -->
  <!-- BASE -->
  <!-- ====================================================== -->

  <link name="base_link">

    <visual>
      <geometry>
        <box size="0.10 0.10 0.06"/>
      </geometry>
      <origin xyz="0 0 0.03"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.10 0.10 0.06"/>
      </geometry>
      <origin xyz="0 0 0.03"/>
    </collision>

  </link>

  <!-- ====================================================== -->
  <!-- FIXED COLUMN -->
  <!-- ====================================================== -->

  <link name="column_link">

    <visual>
      <geometry>
        <box size="0.03 0.03 0.215"/>
      </geometry>
      <origin xyz="0 0 0.1075"/>

      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="0.03 0.03 0.215"/>
      </geometry>
      <origin xyz="0 0 0.1075"/>
    </collision>

  </link>

  <joint name="column_fixed_joint" type="fixed">

    <parent link="base_link"/>
    <child link="column_link"/>

    <!-- top of 10 mm base -->
    <origin xyz="0 0 0.06"/>

  </joint>

  <!-- ====================================================== -->
  <!-- MOVING CARRIAGE -->
  <!-- ====================================================== -->

  <link name="carriage_link">

    <visual>
      <geometry>
        <box size="0.05 0.05 0.046"/>
      </geometry>

      <origin xyz="0 0 0.023"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.05 0.05 0.046"/>
      </geometry>

      <origin xyz="0 0 0.023"/>
    </collision>

  </link>

  <!-- ====================================================== -->
  <!-- ELEVATOR -->
  <!-- ====================================================== -->

  <joint name="lift_joint" type="prismatic">

    <parent link="column_link"/>
    <child link="carriage_link"/>

    <!-- start at bottom of column -->
    <origin xyz="0 0 0"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="0.0"
      upper="0.176"
      effort="50.0"
      velocity="0.10"/>

  </joint>

  <!-- ====================================================== -->
  <!-- LINK 1 -->
  <!-- ====================================================== -->

  <link name="link1">

    <visual>
      <geometry>
        <box size="0.153 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0765 0 0"/>

      <material name="blue">
        <color rgba="0.2 0.2 1.0 1.0"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="0.153 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0765 0 0"/>
    </collision>

  </link>

  <!-- ====================================================== -->
  <!-- JOINT 1 -->
  <!-- ====================================================== -->

  <joint name="joint1" type="revolute">

    <parent link="carriage_link"/>
    <child link="link1"/>

    <!-- shoulder axis through center of carriage -->
    <origin xyz="0 0 0.023"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="-2.007"
      upper="2.007"
      effort="5.0"
      velocity="1.0"/>

  </joint>

  <!-- ====================================================== -->
  <!-- LINK 2 -->
  <!-- ====================================================== -->

  <link name="link2">

    <visual>
      <geometry>
        <box size="0.153 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0765 0 0"/>

      <material name="blue"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.153 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0765 0 0"/>
    </collision>

  </link>

  <!-- ====================================================== -->
  <!-- JOINT 2 -->
  <!-- ====================================================== -->

  <joint name="joint2" type="revolute">

    <parent link="link1"/>
    <child link="link2"/>

    <origin xyz="0.153 0 0"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="-2.007"
      upper="2.007"
      effort="5.0"
      velocity="1.0"/>

  </joint>

  <!-- ====================================================== -->
  <!-- TOOL -->
  <!-- ====================================================== -->

  <link name="tool_link">

    <visual>
      <geometry>
        <box size="0.043 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0215 0 0"/>

      <material name="red">
        <color rgba="1.0 0.2 0.2 1.0"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="0.043 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0215 0 0"/>
    </collision>

  </link>

  <!-- ====================================================== -->
  <!-- JOINT 3 -->
  <!-- ====================================================== -->

  <joint name="joint3" type="revolute">

    <parent link="link2"/>
    <child link="tool_link"/>

    <origin xyz="0.153 0 0"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="-2.007"
      upper="2.007"
      effort="5.0"
      velocity="1.0"/>

  </joint>

</robot>