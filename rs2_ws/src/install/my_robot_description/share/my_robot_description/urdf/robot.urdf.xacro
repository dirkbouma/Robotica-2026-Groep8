<?xml version="1.0"?>

<robot name="planar_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ====================================================== -->
  <!-- BASE -->
  <!-- ====================================================== -->

  <link name="base_link">

    <visual>
      <geometry>
        <box size="0.03 0.03 0.21"/>
      </geometry>

      <!-- center base -->
      <origin xyz="0 0 0.105"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.03 0.03 0.21"/>
      </geometry>

      <origin xyz="0 0 0.105"/>
    </collision>

  </link>


  <!-- ====================================================== -->
  <!-- LINK 1 -->
  <!-- ====================================================== -->

  <link name="link1">

    <visual>
      <geometry>
        <box size="0.157 0.022 0.046"/>
      </geometry>

      <!-- center of link -->
      <origin xyz="0.0765 0 0"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.157 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0765 0 0"/>
    </collision>

  </link>


  <!-- ====================================================== -->
  <!-- JOINT 1 -->
  <!-- ====================================================== -->

  <joint name="joint1" type="revolute">

    <parent link="base_link"/>
    <child link="link1"/>

    <!-- top of base -->
    <origin xyz="0 0 0.21"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="-2.6"
      upper="2.6"
      effort="1.0"
      velocity="1.0"/>

  </joint>


  <!-- ====================================================== -->
  <!-- LINK 2 -->
  <!-- ====================================================== -->

  <link name="link2">

    <visual>
      <geometry>
        <box size="0.153 0.022 0.046"/>
      </geometry>

      <!-- center of link -->
      <origin xyz="0.0765 0 0"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.153 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0765 0 0"/>
    </collision>

  </link>


  <!-- ====================================================== -->
  <!-- JOINT 2 -->
  <!-- ====================================================== -->

  <joint name="joint2" type="revolute">

    <parent link="link1"/>
    <child link="link2"/>

    <!-- end of link1 -->
    <origin xyz="0.153 0 0"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="-2.6"
      upper="2.6"
      effort="1.0"
      velocity="1.0"/>

  </joint>


  <!-- ====================================================== -->
  <!-- TOOL -->
  <!-- ====================================================== -->

  <link name="tool_link">

    <visual>
      <geometry>
        <box size="0.043 0.022 0.046"/>
      </geometry>

      <!-- center of tool -->
      <origin xyz="0.0215 0 0"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.043 0.022 0.046"/>
      </geometry>

      <origin xyz="0.0215 0 0"/>
    </collision>

  </link>


  <!-- ====================================================== -->
  <!-- JOINT 3 -->
  <!-- ====================================================== -->

  <joint name="joint3" type="revolute">

    <parent link="link2"/>
    <child link="tool_link"/>

    <!-- end of link2 -->
    <origin xyz="0.153 0 0"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="-2.6"
      upper="2.6"
      effort="1.0"
      velocity="1.0"/>

  </joint>

</robot>